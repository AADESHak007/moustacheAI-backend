# =============================================================================
# Environment Variables — AI Mustache Generator Backend
# Copy to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# --- Supabase ---
# Found in: Supabase Dashboard → Settings → API

# Your project URL (e.g. https://abcdef.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key — has full DB/Storage access. Keep secret. Server-side only.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Anon/Public Key — used for client-side auth flows if needed
SUPABASE_ANON_KEY=your-anon-key-here

# --- Storage Buckets ---
# These must be created in Supabase Storage as PRIVATE buckets
UPLOADS_BUCKET=uploads
RESULTS_BUCKET=results
ASSETS_BUCKET=assets

# --- File Validation ---
MAX_FILE_SIZE_MB=5
MAX_IMAGE_DIMENSION=4000

# --- Rate Limiting ---
RATE_LIMIT=5/minute

# --- App ---
DEBUG=false
CORS_ORIGINS=["*"]
