# =============================================================================
# Environment Variables — AI Mustache Generator Backend
# Copy to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# --- Supabase ---
# Found in: Supabase Dashboard → Settings → API

# Your project URL (e.g. https://abcdef.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key — full DB + Storage access. Server-side ONLY. Keep secret!
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Anon/Public Key — used for Supabase Auth flows (sign-up, sign-in, token verify)
SUPABASE_ANON_KEY=your-anon-key-here

# --- Storage Buckets ---
# Create these as PRIVATE buckets in Supabase Dashboard → Storage
UPLOADS_BUCKET=uploads       # original user selfies
RESULTS_BUCKET=results       # AI-generated mustache images

# --- Signed URL Expiry ---
# How long (seconds) signed Storage URLs remain valid. Default: 1 hour.
SIGNED_URL_EXPIRY_SECONDS=3600

# --- File Validation ---
MAX_FILE_SIZE_MB=5
MAX_IMAGE_DIMENSION=4000

# --- Rate Limiting ---
RATE_LIMIT=5/minute

# --- CORS ---
# Comma-separated list of allowed origins. Use ["*"] for development only.
CORS_ORIGINS=["*"]

# --- AI ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Razorpay (payments) ---
# Found in: Razorpay Dashboard → Settings → API Keys
# Use test keys (rzp_test_*) for development; switch to live keys in prod.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Set this in: Razorpay Dashboard → Settings → Webhooks
# Subscribe to event: payment.captured  · URL: https://<your-host>/api/billing/webhook
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# --- Credits ---
# How many free generations a brand-new user gets the first time they
# call any credit-gated endpoint.
FREE_SIGNUP_CREDITS=3

# --- App ---
DEBUG=false
